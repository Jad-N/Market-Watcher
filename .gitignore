# Operational noise — regenerated each run, not needed in version control.
# (build feed data.js still writes/reads Briefs/<today>/intraday raw.json during the
#  job; gitignore only stops it being committed, not from existing on disk.)
Briefs/
*.log
node_modules/

# Local dev / preview throwaways (not part of the cloud build)
docs/_*
_seed-fixture.js
_review*.png
_crop*.png
_c_*.png

# Local environment certs
*.cer
Certificate.cer

# X-feed probe (Step 1 measurement): the residential-IP log stays local; only the
# runner-IP log (x-probe-log.csv, committed by the x-probe workflow) is tracked.
*.local.csv
